{
  "plugins": ["prettier"],
  "extends": ["airbnb", "airbnb-typescript", "plugin:prettier/recommended", "next/core-web-vitals"],
  "parserOptions": {
    "project": "./tsconfig.json"
  },
  "rules": {
    "object-curly-newline": "off",
    "react/jsx-props-no-spreading": "off",
    "prettier/prettier": ["error", { "singleQuote": true }]
  }
}
